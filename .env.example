# Copy to .env.local and fill in. Never commit .env.local.

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS. Never expose to the browser or log it.
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (Project Settings -> Database -> Connection string, "Session pooler" or direct) ---
# Used by Drizzle for migrations and the RLS-respecting query client.
DATABASE_URL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- AI providers (server-only) ---
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# --- Jobs (Inngest, server-only) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Observability ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
